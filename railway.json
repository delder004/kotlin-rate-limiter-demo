{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "./gradlew --no-daemon installDist"
  },
  "deploy": {
    "startCommand": "./build/install/test-rate-limiter/bin/test-rate-limiter",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
